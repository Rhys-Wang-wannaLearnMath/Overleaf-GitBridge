{
  "name": "overleaf-gitbridge",
  "displayName": "Overleaf GitBridge",
  "description": "Overleaf Git sync + remote PDF preview for VS Code",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/placeholder/overleaf-gitbridge"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.git/config",
    "onView:overleaf-gitbridge.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "overleaf-gitbridge.cloneProject",
        "title": "Overleaf GitBridge: Clone Project",
        "icon": "$(cloud-download)"
      },
      {
        "command": "overleaf-gitbridge.configureToken",
        "title": "Overleaf GitBridge: Configure Git Token"
      },
      {
        "command": "overleaf-gitbridge.configureCookie",
        "title": "Overleaf GitBridge: Configure Cookie"
      },
      {
        "command": "overleaf-gitbridge.clearCredentials",
        "title": "Overleaf GitBridge: Clear All Credentials"
      },
      {
        "command": "overleaf-gitbridge.startSync",
        "title": "Overleaf GitBridge: Start Git Sync"
      },
      {
        "command": "overleaf-gitbridge.stopSync",
        "title": "Overleaf GitBridge: Stop Git Sync"
      },
      {
        "command": "overleaf-gitbridge.startPdfPreview",
        "title": "Overleaf GitBridge: Start PDF Preview"
      },
      {
        "command": "overleaf-gitbridge.stopPdfPreview",
        "title": "Overleaf GitBridge: Stop PDF Preview"
      },
      {
        "command": "overleaf-gitbridge.refreshPdf",
        "title": "Overleaf GitBridge: Refresh PDF"
      },
      {
        "command": "overleaf-gitbridge.showOutput",
        "title": "Overleaf GitBridge: Show Output Log",
        "icon": "$(output)"
      },
      {
        "command": "overleaf-gitbridge.openSettings",
        "title": "Overleaf GitBridge: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "overleaf-gitbridge.resolveConflict.pull",
        "title": "Overleaf GitBridge: Resolve Conflict — Pull & Merge"
      },
      {
        "command": "overleaf-gitbridge.resolveConflict.forcePush",
        "title": "Overleaf GitBridge: Resolve Conflict — Force Push"
      },
      {
        "command": "overleaf-gitbridge.resolveConflict.diff",
        "title": "Overleaf GitBridge: Resolve Conflict — Open Diff"
      },
      {
        "command": "overleaf-gitbridge.resolveConflict.terminal",
        "title": "Overleaf GitBridge: Resolve Conflict — Open Terminal"
      }
    ],
    "configuration": {
      "title": "Overleaf GitBridge",
      "properties": {
        "overleaf-gitbridge.serverUrl": {
          "type": "string",
          "default": "https://www.overleaf.com",
          "description": "Overleaf server URL"
        },
        "overleaf-gitbridge.quietSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 300,
          "description": "Seconds to wait after last local edit before auto-commit (quiet period)"
        },
        "overleaf-gitbridge.pollSeconds": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 60,
          "description": "Git status polling interval in seconds"
        },
        "overleaf-gitbridge.pdfPollSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 300,
          "description": "PDF periodic polling interval in seconds (0 = only trigger after push)"
        },
        "overleaf-gitbridge.formatter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable built-in LaTeX formatter (Prettier + unified-latex)"
        },
        "overleaf-gitbridge.formatter.lineBreak": {
          "type": "boolean",
          "default": true,
          "description": "Auto-wrap lines at printWidth when formatting LaTeX"
        },
        "overleaf-gitbridge.formatter.printWidth": {
          "type": "number",
          "default": 80,
          "minimum": 40,
          "maximum": 300,
          "description": "Line width for LaTeX formatting (when lineBreak is enabled)"
        },
        "overleaf-gitbridge.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".*"
          ],
          "description": "Additional file/folder patterns to ignore during Git sync (glob format). '.output*' is always ignored."
        },
        "overleaf-gitbridge.conflictStrategy": {
          "type": "string",
          "enum": [
            "smart-merge",
            "always-ask",
            "local-first",
            "remote-first"
          ],
          "default": "smart-merge",
          "enumDescriptions": [
            "Auto-merge different files; pause and show diff for same-file conflicts",
            "Always pause and ask before merging any remote changes",
            "When same file conflicts, prefer local version",
            "When same file conflicts, prefer remote (Overleaf) version"
          ],
          "description": "How to handle conflicts when remote collaborators modify files on Overleaf"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "overleaf-gitbridge",
          "title": "Overleaf GitBridge",
          "icon": "resources/overleaf.svg"
        }
      ]
    },
    "views": {
      "overleaf-gitbridge": [
        {
          "id": "overleaf-gitbridge.sidebar",
          "name": "Overleaf GitBridge",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "overleaf-gitbridge.cloneProject",
          "when": "view == overleaf-gitbridge.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "overleaf-gitbridge.showOutput",
          "when": "view == overleaf-gitbridge.sidebar",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "overleaf-gitbridge.refreshPdf",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      },
      {
        "command": "overleaf-gitbridge.startSync",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/node-fetch": "^2.6.9",
    "@unified-latex/unified-latex-prettier": "^1.8.3",
    "node-fetch": "^2.7.0",
    "prettier": "^3.8.1"
  }
}