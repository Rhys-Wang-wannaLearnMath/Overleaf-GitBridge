{
  "name": "overleaf-gitlive",
  "displayName": "Overleaf GitLive",
  "description": "Two-way Git sync and remote PDF preview for Overleaf projects — auto commit/push/pull, smart conflict resolution, one-click clone, and built-in LaTeX formatter.",
  "version": "0.1.2",
  "publisher": "RhysWang0405-vsc-studio",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rhys-Wang-wannaLearnMath/Overleaf-GitLive"
  },
  "categories": [
    "Other",
    "SCM Providers",
    "Formatters"
  ],
  "keywords": [
    "overleaf",
    "latex",
    "git",
    "sync",
    "pdf",
    "preview",
    "tex"
  ],
  "galleryBanner": {
    "color": "#4F8A10",
    "theme": "dark"
  },
  "homepage": "https://github.com/Rhys-Wang-wannaLearnMath/Overleaf-GitLive#readme",
  "bugs": {
    "url": "https://github.com/Rhys-Wang-wannaLearnMath/Overleaf-GitLive/issues"
  },
  "markdown": "github",
  "qna": "marketplace",
  "activationEvents": [
    "workspaceContains:.git/config",
    "onView:overleaf-gitlive.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "overleaf-gitlive.cloneProject",
        "title": "Overleaf GitLive: Clone Project",
        "icon": "$(cloud-download)"
      },
      {
        "command": "overleaf-gitlive.configureToken",
        "title": "Overleaf GitLive: Configure Git Token"
      },
      {
        "command": "overleaf-gitlive.configureCookie",
        "title": "Overleaf GitLive: Configure Cookie"
      },
      {
        "command": "overleaf-gitlive.clearCredentials",
        "title": "Overleaf GitLive: Clear All Credentials"
      },
      {
        "command": "overleaf-gitlive.startSync",
        "title": "Overleaf GitLive: Start Git Sync"
      },
      {
        "command": "overleaf-gitlive.stopSync",
        "title": "Overleaf GitLive: Stop Git Sync"
      },
      {
        "command": "overleaf-gitlive.startPdfPreview",
        "title": "Overleaf GitLive: Start PDF Preview"
      },
      {
        "command": "overleaf-gitlive.stopPdfPreview",
        "title": "Overleaf GitLive: Stop PDF Preview"
      },
      {
        "command": "overleaf-gitlive.refreshPdf",
        "title": "Overleaf GitLive: Refresh PDF"
      },
      {
        "command": "overleaf-gitlive.showOutput",
        "title": "Overleaf GitLive: Show Output Log",
        "icon": "$(output)"
      },
      {
        "command": "overleaf-gitlive.openSettings",
        "title": "Overleaf GitLive: Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "overleaf-gitlive.resolveConflict.pull",
        "title": "Overleaf GitLive: Resolve Conflict — Pull & Merge"
      },
      {
        "command": "overleaf-gitlive.resolveConflict.forcePush",
        "title": "Overleaf GitLive: Resolve Conflict — Force Push"
      },
      {
        "command": "overleaf-gitlive.resolveConflict.diff",
        "title": "Overleaf GitLive: Resolve Conflict — Open Diff"
      },
      {
        "command": "overleaf-gitlive.resolveConflict.terminal",
        "title": "Overleaf GitLive: Resolve Conflict — Open Terminal"
      },
      {
        "command": "overleaf-gitlive.resolveConflict.markResolved",
        "title": "Overleaf GitLive: Resolve Conflict — Mark Resolved"
      },
      {
        "command": "overleaf-gitlive.viewCommitDiff",
        "title": "Overleaf GitLive: View Commit Diff",
        "icon": "$(git-compare)"
      }
    ],
    "configuration": {
      "title": "Overleaf GitLive",
      "properties": {
        "overleaf-gitlive.serverUrl": {
          "type": "string",
          "default": "https://www.overleaf.com",
          "description": "Overleaf server URL"
        },
        "overleaf-gitlive.pollSeconds": {
          "type": "number",
          "default": 1,
          "minimum": 1,
          "maximum": 60,
          "description": "Git status polling interval in seconds"
        },
        "overleaf-gitlive.pdfPollSeconds": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 300,
          "description": "PDF periodic polling interval in seconds (0 = only trigger after push)"
        },
        "overleaf-gitlive.formatter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable built-in LaTeX formatter (Prettier + unified-latex)"
        },
        "overleaf-gitlive.formatter.lineBreak": {
          "type": "boolean",
          "default": true,
          "description": "Auto-wrap lines at printWidth when formatting LaTeX"
        },
        "overleaf-gitlive.formatter.printWidth": {
          "type": "number",
          "default": 80,
          "minimum": 40,
          "maximum": 300,
          "description": "Line width for LaTeX formatting (when lineBreak is enabled)"
        },
        "overleaf-gitlive.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".*"
          ],
          "description": "Additional file/folder patterns to ignore during Git sync (glob format). '.output*' is always ignored."
        },
        "overleaf-gitlive.autoStart": {
          "type": "string",
          "enum": [
            "off",
            "ask",
            "sync"
          ],
          "default": "off",
          "enumDescriptions": [
            "Do nothing on activation",
            "Show a notification asking whether to start sync/PDF preview",
            "Automatically start Git sync when an Overleaf project is detected"
          ],
          "description": "Behavior when an Overleaf project is detected on activation"
        },
        "overleaf-gitlive.diffViewMode": {
          "type": "string",
          "enum": [
            "sidebar",
            "quickpick"
          ],
          "default": "sidebar",
          "enumDescriptions": [
            "Browse and select commit diffs in the sidebar panel",
            "Use a QuickPick popup to select commit range"
          ],
          "description": "Where to browse and select commit diffs for review"
        },
        "overleaf-gitlive.conflictStrategy": {
          "type": "string",
          "enum": [
            "smart-merge",
            "always-ask",
            "local-first",
            "remote-first"
          ],
          "default": "smart-merge",
          "enumDescriptions": [
            "Auto-merge different files; pause and show diff for same-file conflicts",
            "Always pause and ask before merging any remote changes",
            "When same file conflicts, prefer local version",
            "When same file conflicts, prefer remote (Overleaf) version"
          ],
          "description": "How to handle conflicts when remote collaborators modify files on Overleaf"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "overleaf-gitlive",
          "title": "Overleaf GitLive",
          "icon": "resources/overleaf.svg"
        }
      ]
    },
    "views": {
      "overleaf-gitlive": [
        {
          "id": "overleaf-gitlive.sidebar",
          "name": "Overleaf GitLive",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "overleaf-gitlive.cloneProject",
          "when": "view == overleaf-gitlive.sidebar",
          "group": "navigation@1"
        },
        {
          "command": "overleaf-gitlive.showOutput",
          "when": "view == overleaf-gitlive.sidebar",
          "group": "navigation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "overleaf-gitlive.refreshPdf",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      },
      {
        "command": "overleaf-gitlive.startSync",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      },
      {
        "command": "overleaf-gitlive.viewCommitDiff",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@types/node-fetch": "^2.6.9",
    "@unified-latex/unified-latex-prettier": "^1.8.3",
    "node-fetch": "^2.7.0",
    "prettier": "^3.8.1"
  }
}